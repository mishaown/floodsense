# Auto detect text files and perform LF normalization
* text=auto

# Python files
*.py text diff=python

# Configuration
*.yaml text
*.yml text
*.json text

# Documentation
*.md text diff=markdown
*.txt text

# Binary files
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.tif binary
*.tiff binary
*.pt binary
*.pth binary
*.onnx binary

# Shell scripts
*.sh text eol=lf

# Windows batch
*.bat text eol=crlf
*.cmd text eol=crlf
